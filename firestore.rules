rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    match /sessions/{document} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.minutes is int
        && request.resource.data.completedAtISO is string
        && request.resource.data.category is string
        && request.resource.data.note is string
        && request.resource.data.noteSavedAtISO is string;

      allow read, update, delete: if request.auth != null
        && request.auth.uid == resource.data.uid;
    }

    match /feedback/{document} {
      allow create: if request.auth != null
        && request.auth.uid == request.resource.data.uid
        && request.resource.data.category is string
        && request.resource.data.message is string
        && request.resource.data.createdAtISO is string;

      allow read, update, delete: if false;
    }

    match /userNotes/{uid} {
      allow read: if request.auth != null
        && request.auth.uid == uid;

      allow create, update: if request.auth != null
        && request.auth.uid == uid
        && request.resource.data.uid == request.auth.uid;

      allow delete: if request.auth != null
        && request.auth.uid == uid;

      // Individual note documents — new subcollection structure.
      // Each note is its own document so concurrent writes never overwrite each other.
      match /notes/{noteId} {
        allow read, write: if request.auth != null
          && request.auth.uid == uid;
      }
    }

    match /userPreferences/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /userReflectionState/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /userPlannedBlocks/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /userCards/{uid} {
      allow read, write: if request.auth != null && request.auth.uid == uid;
    }

    match /analyticsEvents/{document} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.eventId is string
        && request.resource.data.eventName is string
        && request.resource.data.userId is string
        && request.resource.data.occurredAt is string
        && request.resource.data.occurredDateLocal is string
        && request.resource.data.clientTimezone is string
        && request.resource.data.clientPlatform is string;

      allow delete: if false;
    }

    match /analyticsDailyMetrics/{document} {
      allow read: if request.auth != null
        && request.auth.uid == resource.data.userId;

      allow create, update: if request.auth != null
        && request.auth.uid == request.resource.data.userId
        && request.resource.data.userId is string
        && request.resource.data.dateLocal is string
        && request.resource.data.timezone is string
        && request.resource.data.updatedAtISO is string;

      allow delete: if false;
    }

    match /leaderboardProfiles/{userId} {
      allow read: if request.auth != null;

      allow create, update: if request.auth != null
        && request.auth.uid == userId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.username is string
        && request.resource.data.usernameLower is string
        && request.resource.data.createdAtISO is string
        && request.resource.data.updatedAtISO is string;

      allow delete: if false;
    }

    match /friendships/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /friends/{friendUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update, delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == friendUid);
      }
    }

    match /friendRequests/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;

      match /incoming/{fromUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null && request.auth.uid == fromUid;
        allow delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == fromUid);
      }

      match /outgoing/{toUid} {
        allow read: if request.auth != null && request.auth.uid == uid;
        allow create, update: if request.auth != null && request.auth.uid == uid;
        allow delete: if request.auth != null
          && (request.auth.uid == uid || request.auth.uid == toUid);
      }
    }

    match /leaderboardSnapshotRuns/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }

    match /leaderboardDailySnapshots/{document} {
      allow read: if request.auth != null;
      allow create, update, delete: if false;
    }
  }
}
